# Application Settings
VITE_DEFAULT_THEME=dark
VITE_DEFAULT_LANGUAGE=en

# Development Server Port (npm run dev - default 5173)
VITE_DEV_SERVER_PORT=5173

# =====================================================================
# AI PROVIDERS (Optional - Required for AI features)
# =====================================================================

# ⚠️ AI FEATURE WARNING: The AI functionality is experimental and may
# not work as expected. Use at your own risk.

# =====================================================================
# LOCAL AI PROVIDERS (Free & Private)
# =====================================================================

# Ollama (https://ollama.ai/)
# Models recommandés (télécharger avec: ollama pull <model>):
#   qwen2.5:4b                     - Qwen3.5-4B
#   ministral-3b-instruct-2512     - Ministral 3B Instruct
#   llama3.1:8b                    - Meta-Llama-3-8B-Instruct
# No API key required - uses local endpoint
VITE_OLLAMA_BASE_URL=http://localhost:11434/api/generate
VITE_OLLAMA_MODEL=qwen2.5:4b

# LM Studio (https://lmstudio.ai/)
# 1. Download and install LM Studio
# 2. Load a model and start the server
# 3. Use the local endpoint
VITE_LMSTUDIO_BASE_URL=http://localhost:1234/v1/chat/completions
VITE_LMSTUDIO_MODEL=

# =====================================================================
# CLOUD AI PROVIDERS (Require API keys)
# =====================================================================

# OpenAI (https://platform.openai.com/)
VITE_OPENAI_API_KEY=sk-...
VITE_OPENAI_MODEL=gpt-5.4-pro

# Anthropic Claude (https://console.anthropic.com/)
VITE_ANTHROPIC_API_KEY=sk-ant-...
VITE_ANTHROPIC_MODEL=claude-4.6-sonnet

# Google AI (https://ai.google.dev/)
VITE_GOOGLE_AI_API_KEY=...
VITE_GOOGLE_AI_MODEL=gemini-3.1-pro

# xAI Grok (https://x.ai/)
VITE_XAI_API_KEY=xai-...
VITE_XAI_MODEL=grok-4.20

# Google AI (https://ai.google.dev/)
# Models: gemini-pro, gemini-ultra
VITE_GOOGLE_AI_API_KEY=...
VITE_GOOGLE_AI_MODEL=gemini-pro

# =====================================================================
# CONFIGURATION NOTES
# =====================================================================

# Local AI Providers (Ollama, LM Studio):
# - Completely free
# - Privacy-focused (data stays on your machine)
# - Requires downloading models (1-10GB)
# - May be slower than cloud providers
# - Recommended for privacy and testing

# Cloud AI Providers (OpenAI, Anthropic, Google):
# - Require API keys (sign up on respective platforms)
# - Pay-per-use pricing
# - Faster responses
# - More powerful models
# - Data sent to external servers

# To use:
# 1. Copy this file to .env.local
# 2. Uncomment and fill in the credentials for your chosen provider
# 3. Restart the development server: npm run dev
